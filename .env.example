# Macena CS2 Analyzer — Environment Variables
#
# Copy this file to .env and fill in your values.
# Only STEAM_API_KEY is required for basic functionality.
# All other variables have sensible defaults.

# ============ Required for Steam Integration ============
STEAM_API_KEY=              # Steam Web API key (https://steamcommunity.com/dev/apikey)
STEAM_ID=                   # Your Steam64 ID (find at steamid.io)

# ============ Optional: Local LLM (Ollama) ============
OLLAMA_URL=http://localhost:11434   # Ollama server endpoint
OLLAMA_MODEL=llama3.1:8b           # Model name for coaching dialogue (8B general-purpose)

# ============ Optional: HLTV Pro Stats Scraping ============
FLARESOLVERR_URL=http://localhost:8191/v1  # FlareSolverr proxy (requires Docker)

# ============ Optional: Error Tracking ============
SENTRY_DSN=                 # Sentry DSN for error reporting (double opt-in: also needs UI toggle)

# ============ Optional: Telemetry ============
CS2_TELEMETRY_URL=http://127.0.0.1:8000   # Local telemetry endpoint
CS2_TELEMETRY_PATH=                         # Telemetry data storage directory

# ============ Optional: Runtime Integrity ============
CS2_MANIFEST_KEY=           # HMAC key for integrity manifests (production builds)

# ============ Optional: Logging ============
CS2_LOG_LEVEL=              # Override log level (DEBUG, INFO, WARNING, ERROR)

# ============ Optional: Performance ============
HP_MODE=0                   # High-performance mode (1=enabled, boosts process priority)

# ============ Dev/CI Only ============
# CS2_INTEGRATION_TESTS=1  # Enable integration tests (requires database.db)
# CS2_LATENCY_MULTIPLIER=3.0  # CI latency tolerance multiplier
# CI=1                      # CI environment indicator
# GITHUB_ACTIONS=1          # GitHub Actions indicator
