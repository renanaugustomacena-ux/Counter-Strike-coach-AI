runs/

# Stage-4 relocation: repo-root training-artifact dirs are deprecated. The
# canonical location is Programma_CS2_RENAN/models and .../runs (routed via
# core/config.py MODELS_DIR / RUNS_DIR). Keep the root paths out of git so a
# stale CWD from an old command cannot resurface them.
/models/

