# --- Line-ending policy (2026-07-02) ---------------------------------------
# The index is historically mixed (478 CRLF / 623 LF tracked text files from
# the project's Windows-born history). Do NOT renormalize globally
# (`git add --renormalize .` is forbidden without an owner-approved plan).
# Phantom-churn defense is repo-local config: core.filemode=false,
# core.autocrlf=input. Rules below pin only classes that must never flip.
# Consequence of autocrlf=input: editing a CRLF-index file lazily normalizes
# that one file to LF in its next commit (expected, incremental convergence).

# Shell scripts break under bash with CRLF — always LF.
*.sh text eol=lf

# Windows batch files require CRLF.
*.bat text eol=crlf

